#!/bin/bash
# ClawApp FPK - fnOS 生命周期脚本
# 由 fnOS 在安装/启动/停止/卸载时调用

# ── fnOS 标准变量（由 common 脚本或 fnOS 框架注入）────────────────
# INST_VARIABLES   = /var/apps/clawapp/etc/installer-variables
# TRIM_APPNAME     = clawapp
# TRIM_APPDEST     = /opt/clawapp
# TRIM_PKGVAR      = /opt/clawapp/data
# TRIM_MODE        = install | uninstall | start | stop | restart
# TRIM_TEMP_LOGFILE = /tmp/trim_<uuid>.log（错误信息输出路径）

SVC_BACKGROUND=y
SVC_WRITE_PID=y
SVC_CWD="${TRIM_PKGVAR}"

INST_ETC="/var/apps/${TRIM_APPNAME}/etc"
INST_VARIABLES="${INST_ETC}/installer-variables"
DATA_DIR="${TRIM_PKGVAR}"
LOG_FILE="${DATA_DIR}/clawapp.log"
PID_FILE="${DATA_DIR}/clawapp.pid"
CONF_FILE="${DATA_DIR}/.env"

# ── 错误处理 ────────────────────────────────────────────────────────
error_exit() {
    local msg="$1"
    echo "ERROR: $msg" >&2
    if [ -n "${TRIM_TEMP_LOGFILE:-}" ]; then
        echo "$msg" > "$TRIM_TEMP_LOGFILE"
    fi
    exit 1
}

# ── fnOS 配置表单 ───────────────────────────────────────────────────
# initialize_variables 由 fnOS 框架调用（installer 会 source 本脚本）
# 输出安装向导的配置表单（YAML 格式）
initialize_variables() {
    # 从 installer-variables 加载已有配置
    load_variables_from_file "${INST_VARIABLES}"

    # fnOS wizard YAML 格式（shell 变量在 heredoc 内展开）
    cat << WIZARD
field:
  name: proxy_port
  type: number
  label: 服务端口
  default: "${proxy_port:-3210}"
  min: 1024
  max: 65535
  required: true
  hint: ClawApp Web 服务端口

field:
  name: gateway_url
  type: text
  label: OpenClaw Gateway 地址
  default: "${gateway_url:-ws://127.0.0.1:18789}"
  required: true
  hint: 本机填 ws://127.0.0.1:18789

field:
  name: gateway_token
  type: text
  label: Gateway Token（选填）
  default: "${gateway_token:-}"
  required: false
  hint: 如 Gateway 有 Token 认证，填入此项
WIZARD
}

load_variables_from_file "${INST_VARIABLES}"

do_install() {
    mkdir -p "${DATA_DIR}/dist" "${DATA_DIR}/logs"

    # 首次安装 → 使用向导配置的值（INSTALL variables）
    if [ -f "${INST_VARIABLES}" ]; then
        . "${INST_VARIABLES}"
    fi

    # 写入 .env 配置文件（Node.js 服务端读取）
    RANDOM_TOKEN="${proxy_token:-$(python3 -c "import secrets; print(secrets.token_urlsafe(12))")}"
    cat > "${CONF_FILE}" << EOF
PROXY_PORT=${proxy_port:-3210}
PROXY_TOKEN=${RANDOM_TOKEN}
SETUP_PENDING=true
OPENCLAW_GATEWAY_URL=${gateway_url:-ws://127.0.0.1:18789}
OPENCLAW_GATEWAY_TOKEN=${gateway_token:-}
OPENCLAW_GATEWAY_PASSWORD=${gateway_password:-}
EOF

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ClawApp 安装完成，端口:${proxy_port:-3210}，密码:$RANDOM_TOKEN" >> "${LOG_FILE}"
}

do_start() {
    cd "${TRIM_APPDEST}" || exit 1

    if [ -f "${PID_FILE}" ]; then
        OLD_PID=$(cat "${PID_FILE}")
        if kill -0 "$OLD_PID" 2>/dev/null; then
            return
        fi
        rm -f "${PID_FILE}"
    fi

    # 加载配置
    [ -f "${CONF_FILE}" ] && . "${CONF_FILE}"

    nohup node ./server/index.mjs >> "${DATA_DIR}/logs/server.log" 2>&1 &
    PID=$!
    echo "$PID" > "${PID_FILE}"
    sleep 2

    if ! kill -0 "$PID" 2>/dev/null; then
        error_exit "ClawApp 启动失败，查看日志: ${DATA_DIR}/logs/server.log"
    fi
}

do_stop() {
    if [ -f "${PID_FILE}" ]; then
        kill $(cat "${PID_FILE}") 2>/dev/null || true
        rm -f "${PID_FILE}"
    fi
    pkill -f "node.*server/index.mjs" 2>/dev/null || true
}

do_uninstall() {
    do_stop
}

# ── 主逻辑 ─────────────────────────────────────────────────────────
case "${TRIM_MODE}" in
    install)
        do_install
        do_start
        ;;
    uninstall)
        do_uninstall
        ;;
    start)
        do_start
        ;;
    stop)
        do_stop
        ;;
    restart)
        do_stop
        sleep 1
        do_start
        ;;
    *)
        echo "Unknown mode: ${TRIM_MODE}" >&2
        ;;
esac

exit 0
